# HermesWork Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3500
NODE_ENV=development

# Stripe — get from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# x402 Protocol
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_WALLET_ADDRESS=0x_your_wallet_address_here
PAYMENT_ADDRESS=0x_your_wallet_address_here

# Blockchain (Base Sepolia)
BASE_SEPOLIA_RPC=https://sepolia.base.org
PRIVATE_KEY=0x_your_private_key_here
ERC8004_REGISTRY=0x_registry_address_here

# Telegram Bot — get from t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# AI / LLM — get from openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
HERMES_MODEL=nvidia/nemotron-3-ultra:free
