# HermesWork Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server
PORT=3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenRouter (Nemotron 3 Ultra)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Blockchain (Base Sepolia)
PRIVATE_KEY=your_wallet_private_key
RPC_URL=https://sepolia.base.org
PAYMENT_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# API Auth (used by Zite/frontend)
API_SECRET_KEY=hwk_live_generate_a_secure_random_string

# Memory
MEMORY_PATH=./hermes/MEMORY.md
