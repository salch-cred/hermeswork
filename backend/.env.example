# HermesWork Backend Environment
PORT=3500
NODE_ENV=development

# Public URLs
FRONTEND_URL=http://localhost:4200
PUBLIC_BASE_URL=http://localhost:3500
BACKEND_URL=http://localhost:3500

# Required in production for all write/admin routes
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HERMESWORK_API_KEY=change_me_to_a_long_random_secret

# Demo seed is blocked in production unless this is true
ENABLE_DEMO_SEED=false

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Base Sepolia / ERC-8004
BASE_SEPOLIA_RPC=https://sepolia.base.org
PRIVATE_KEY=0x_your_private_key_here
ERC8004_REGISTRY=0x_your_registry_contract_here
PAYMENT_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e
X402_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# Telegram optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
